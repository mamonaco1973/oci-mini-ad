        <mxCell id="bastion" value="&lt;b&gt;OCI Bastion&lt;/b&gt;&lt;br&gt;PORT_FORWARDING session&lt;br&gt;SSH tunnel to DC (port 22)" parent="region" vertex="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#006FA9;fontSize=12;verticalAlign=middle;spacingTop=0;">
          <mxGeometry x="790" y="60" width="250" height="110" as="geometry" />
        </mxCell>

        <mxCell id="vault" value="&lt;b&gt;OCI Vault&lt;/b&gt;&lt;br&gt;mini-ad-vault-{suffix}&lt;br&gt;5 AD account secrets&lt;br&gt;(admin, jsmith, edavis, rpatel, akumar)" parent="region" vertex="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;">
          <mxGeometry x="790" y="210" width="250" height="120" as="geometry" />
        </mxCell>

        <mxCell id="igw" value="&lt;b&gt;Internet Gateway&lt;/b&gt;&lt;br&gt;Public subnet egress&lt;br&gt;SSH :22 / RDP :3389" parent="region" vertex="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;verticalAlign=middle;fontColor=#333333;">
          <mxGeometry x="790" y="390" width="250" height="100" as="geometry" />
        </mxCell>

        <mxCell id="nat" value="&lt;b&gt;NAT Gateway&lt;/b&gt;&lt;br&gt;Private subnet egress&lt;br&gt;DC outbound internet" parent="region" vertex="1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;verticalAlign=middle;fontColor=#333333;">
          <mxGeometry x="790" y="540" width="250" height="100" as="geometry" />
        </mxCell>

        <!-- Edge: Bastion → DC (SSH tunnel through private subnet) -->
        <!-- Bastion abs: x=840+50=890... actually parent=region abs x=50,y=50 -->
        <!-- bastion left edge abs: 50+790=840, cy=50+60+55=165 -->
        <!-- ad-subnet right abs: 50+20+30+680=780, cy=50+30+50+105=235 -->
        <mxCell id="edge-bastion-dc" value="SSH tunnel" parent="1" edge="1"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;startArrow=none;strokeColor=#006FA9;dashed=1;fontSize=11;fontColor=#006FA9;rounded=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="165" as="sourcePoint" />
            <mxPoint x="780" y="235" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Edge: DC → Linux (LDAP/Kerberos/DNS domain join) -->
        <!-- dc abs center: 50+20+30+260+80=440, y=50+30+50+40+65=235 -->
        <!-- linux abs center: 50+20+30+70+80=250, y=50+30+310+90+65=545 -->
        <mxCell id="edge-dc-linux" value="AD Join / LDAP / Kerberos" parent="1" edge="1"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;startArrow=none;strokeColor=#545B64;fontSize=11;rounded=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="400" y="290" as="sourcePoint" />
            <mxPoint x="250" y="460" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Edge: DC → Windows (LDAP/Kerberos/DNS domain join) -->
        <!-- win abs center: 50+20+30+450+80=630, y same as linux ~545 -->
        <mxCell id="edge-dc-win" value="AD Join / LDAP / Kerberos" parent="1" edge="1"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;startArrow=none;strokeColor=#545B64;fontSize=11;rounded=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="490" y="290" as="sourcePoint" />
            <mxPoint x="630" y="460" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Edge: vm-subnet → IGW (public traffic) -->
        <!-- vm-subnet right abs: 50+20+30+680=780, cy=50+30+310+160=550 -->
        <!-- igw left abs: 50+790=840, cy=50+390+50=490 -->
        <mxCell id="edge-vm-igw" value="" parent="1" edge="1"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=1;startArrow=none;strokeColor=#666666;rounded=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="550" as="sourcePoint" />
            <mxPoint x="840" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Edge: ad-subnet → NAT (DC outbound internet) -->
        <!-- ad-subnet right abs: 780, cy=235 -->
        <!-- nat left abs: 840, cy=50+540+50=640 -->
        <mxCell id="edge-dc-nat" value="" parent="1" edge="1"
          style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=1;startArrow=none;strokeColor=#666666;rounded=0;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="235" as="sourcePoint" />
            <mxPoint x="840" y="640" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
